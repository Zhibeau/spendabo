# Copy this file to .env.local and fill in the values.
# All EXPO_PUBLIC_* variables are inlined at build time (safe for client use).
# NEVER put secret keys here — only public Firebase/Google config values.

# ── Firebase Project config ────────────────────────────────────────────────
# Found in Firebase Console → Project Settings → General → Your apps → Web app
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# ── Google OAuth client IDs ────────────────────────────────────────────────
# Created in Google Cloud Console → APIs & Services → Credentials
# Each platform needs its own OAuth 2.0 Client ID.

# Web client ID (also used inside Expo Go during development)
# Authorised redirect URI must include:
#   https://auth.expo.io/@<your-expo-username>/spendabo
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# iOS client ID (bundle ID must match app.json ios.bundleIdentifier)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# Android client ID (package name must match app.json android.package)
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# ── Backend ────────────────────────────────────────────────────────────────
# Cloud Run service URL (no trailing slash)
EXPO_PUBLIC_API_BASE_URL=https://your-cloud-run-service-url
